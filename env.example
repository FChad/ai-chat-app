# Ollama API Configuration
# Diese Variablen MÜSSEN in der Produktionsumgebung gesetzt werden

# URL der Ollama API (ohne abschließenden Slash)
OLLAMA_API_URL=https://example.com/api

# Benutzername für die API-Authentifizierung
OLLAMA_API_USER=apiuser

# API-Schlüssel für die Authentifizierung
OLLAMA_API_KEY=your_api_key_here

# Produktions-Hinweise:
# 1. Kopieren Sie diese Datei zu .env
# 2. Ersetzen Sie "your_api_key_here" mit Ihrem echten API-Schlüssel
# 3. Stellen Sie sicher, dass alle drei Variablen in der Produktionsumgebung gesetzt sind
# 4. In Cloud-Deployments (Vercel, Netlify, etc.) müssen diese in den Deployment-Settings konfiguriert werden 